generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String    @id @default(uuid())
  firebaseUid String    @unique
  userEmail   String    @unique
  firstName   String?
  lastName    String?
  lastLoginAt DateTime?
  provider    String?
  createdAt   DateTime  @default(now())
  modifiedAt  DateTime?
  isActive    Boolean   @default(true)
}
