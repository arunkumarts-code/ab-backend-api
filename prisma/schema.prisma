generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  uId                    String    @id @default(uuid())
  firebaseUid            String    @unique
  userEmail              String    @unique
  userAvatar             String?
  userNickName           String?
  firstName              String?
  lastName               String?
  lastLoginAt            DateTime?
  provider               String?
  defaultMMId            String
  defaultGameId          String
  defaultBaseUnit        Int
  defaultStartingBalance Int
  uCurrentBalance       Int

  gameProfits Json @default("[]")
  dayProfits  Json @default("[]")

  createdAt  DateTime  @default(now())
  modifiedAt DateTime?
  isActive   Boolean   @default(true)

  userGames UserGame[]
}

model UserGame {
  ugId String @id @default(uuid())

  uId  String @unique
  gmId String 
  mmId String

  ugBaseUnit        Int
  ugStartingBalance Int

  ugResultList Json @default("[]")

  createdAt  DateTime  @default(now())
  modifiedAt DateTime?

  user User @relation(fields: [uId], references: [uId], onDelete: Cascade)

}
