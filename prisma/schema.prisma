generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  uId                    String    @id @default(uuid())
  firebaseUid            String    @unique
  userEmail              String    @unique
  userAvatar             String?
  userNickName           String?
  firstName              String?
  lastName               String?
  lastLoginAt            DateTime?
  provider               String?
  defaultMMId            String
  defaultGameId          String
  defaultBaseUnit        Int
  defaultStartingBalance Int
  uCurrentBalance        Int

  createdAt  DateTime  @default(now())
  modifiedAt DateTime?
  isActive   Boolean   @default(true)

  userGames   UserGame[]
  gameResults GameResult[]
}

model UserGame {
  ugId String @id @default(uuid())

  uId  String @unique
  gmId String
  mmId String

  ugBaseUnit        Int
  ugStartingBalance Int

  ugResultList Json @default("[]")

  createdAt  DateTime  @default(now())
  modifiedAt DateTime?

  user User @relation(fields: [uId], references: [uId], onDelete: Cascade)
}

model GameResult {
  grId String @id @default(uuid())

  uId             String
  startingBalance Int
  endingBalance   Int
  profit          Int
  isWin           Boolean

  createdAt DateTime @default(now())

  user User @relation(fields: [uId], references: [uId], onDelete: Cascade)

  @@index([uId])
  @@index([createdAt])
  @@index([createdAt, uId])
}
