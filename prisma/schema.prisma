generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String    @id @default(uuid())
  firebaseUid String    @unique
  userEmail   String    @unique
  userName    String?
  lastLoginAt DateTime?
  provider    String?
  createdAt   DateTime  @default(now())
}
